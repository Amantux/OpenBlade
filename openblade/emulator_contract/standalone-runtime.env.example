# Locally built standalone emulator image tag
OPENBLADE_EMULATOR_LOCAL_IMAGE=openblade-i3-emulator-local:dev

# Deterministic Scalar i3 defaults
EMULATOR_PROFILE=scalar-i3-50-3
EMULATOR_SLOT_COUNT=50
EMULATOR_DRIVE_COUNT=3
EMULATOR_OCCUPANCY_PERCENT=60
EMULATOR_LATENCY_PROFILE=instant
OPENBLADE_SCALAR_API_ONLY=true

# Per-library identity + host ports
EMULATOR_LIBRARY1_ID=1
EMULATOR_LIBRARY1_NAME=library-1
EMULATOR_LIBRARY1_PORT=8010

EMULATOR_LIBRARY2_ID=2
EMULATOR_LIBRARY2_NAME=library-2
EMULATOR_LIBRARY2_PORT=8011

EMULATOR_LIBRARY3_ID=3
EMULATOR_LIBRARY3_NAME=library-3
EMULATOR_LIBRARY3_PORT=8012

# Standalone emulator UI host/port
EMULATOR_UI_BIND_HOST=0.0.0.0
EMULATOR_UI_PORT=5174

# Optional UI proxy target overrides (no trailing slash)
EMULATOR_UI_TARGET_LIBRARY1_URL=http://openblade-emulator-library-1:8010
EMULATOR_UI_TARGET_LIBRARY2_URL=http://openblade-emulator-library-2:8010
EMULATOR_UI_TARGET_LIBRARY3_URL=http://openblade-emulator-library-3:8010
