{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openblade.incident.v1",
  "title": "OpenBlade Incident Record",
  "description": "Machine- and human-readable incident record. The agent MAY use prior incidents as qualified context only when current evidence is consistent; similar symptoms do not imply identical cause.",
  "type": "object",
  "required": ["incident_id", "opened_at", "environment", "affected_components", "symptoms", "status"],
  "properties": {
    "incident_id": {"type": "string", "pattern": "^INC-[0-9]{8}-[0-9]{3}$"},
    "opened_at": {"type": "string", "format": "date-time"},
    "resolved_at": {"type": ["string", "null"], "format": "date-time"},
    "duration_seconds": {"type": ["integer", "null"], "minimum": 0},
    "environment": {"enum": ["development", "emulator", "real", "ci"]},
    "affected_components": {"type": "array", "items": {"type": "string"}, "description": "canonical component names (glossary.md)"},
    "failure_ids": {"type": "array", "items": {"type": "string", "pattern": "^[A-Z]+-[0-9]{3}$"}},
    "symptoms": {"type": "array", "items": {"type": "string"}},
    "user_impact": {"type": "string"},
    "telemetry": {"type": "array", "items": {"type": "object", "required": ["source", "value"], "properties": {"source": {"type": "string"}, "value": {}}}},
    "changes": {"type": "array", "items": {"type": "string"}, "description": "deployments/config changes near the incident"},
    "hypotheses": {"type": "array", "items": {"type": "object", "required": ["statement", "confidence"], "properties": {"statement": {"type": "string"}, "confidence": {"enum": ["high", "medium", "low", "unknown"]}, "supporting_evidence": {"type": "array", "items": {"type": "string"}}, "conflicting_evidence": {"type": "array", "items": {"type": "string"}}}}},
    "diagnosis": {"type": "string"},
    "diagnosis_confidence": {"enum": ["high", "medium", "low", "unknown"]},
    "actions": {"type": "array", "items": {"type": "object", "required": ["action_id", "outcome"], "properties": {"action_id": {"type": "string"}, "approved_by": {"type": ["string", "null"]}, "outcome": {"enum": ["succeeded", "failed", "skipped", "escalated"]}, "input": {}, "output": {}, "confidence": {"enum": ["high", "medium", "low", "unknown"]}}}},
    "recovery_verification": {"type": "array", "items": {"type": "string"}},
    "root_cause": {"type": ["string", "null"]},
    "root_cause_status": {"enum": ["confirmed", "probable", "unconfirmed", "unknown"]},
    "contributing_factors": {"type": "array", "items": {"type": "string"}},
    "follow_up_actions": {"type": "array", "items": {"type": "string"}},
    "related_runbooks": {"type": "array", "items": {"type": "string"}},
    "documentation_changes": {"type": "array", "items": {"type": "string"}},
    "unresolved_questions": {"type": "array", "items": {"type": "string"}},
    "status": {"enum": ["open", "mitigated", "resolved", "closed"]}
  },
  "additionalProperties": false
}
